{
  "name": "chatseller-dashboard",
  "private": true,
  "version": "1.0.0",
  "description": "ChatSeller Dashboard - Agent IA Commercial pour e-commerce",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "clean": "rm -rf .nuxt dist node_modules/.cache",
    "reset": "npm run clean && npm install && npm run postinstall"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.16",
    "@heroicons/vue": "^2.0.18",
    "@nuxt/image": "^1.3.0",
    "@nuxtjs/supabase": "^1.1.6",
    "@supabase/supabase-js": "^2.38.5",
    "@tailwindcss/forms": "^0.5.7",
    "bcrypt": "^5.1.1",
    "chart.js": "^4.4.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^2.30.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "pinia": "^2.1.7",
    "tailwindcss": "^3.3.6",
    "uuid": "^9.0.1",
    "vue-chartjs": "^5.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nuxt/devtools": "latest",
    "@nuxt/eslint-config": "^0.2.0",
    "@nuxt/types": "^2.18.1",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@pinia/nuxt": "^0.5.1",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/typography": "^0.5.10",
    "@types/bcrypt": "^5.0.2",
    "@types/chart.js": "^2.9.41",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.19.9",
    "@types/uuid": "^9.0.7",
    "eslint": "^8.54.0",
    "nuxt": "^3.8.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": [
      "node",
      "@types/bcrypt",
      "@types/jsonwebtoken",
      "@types/uuid"
    ],
    "paths": {
      "~/*": ["./src/*"],
      "@/*": ["./src/*"],
      "~~/*": ["./*"],
      "@@/*": ["./*"],
      "~/components/*": ["./components/*"],
      "~/composables/*": ["./composables/*"],
      "~/stores/*": ["./stores/*"],
      "~/server/*": ["./server/*"],
      "~/types/*": ["./types/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.vue",
    "**/*.js",
    "types/global.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".nuxt"
  ]
}
